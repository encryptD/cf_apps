<mvc:View
    controllerName="com.mdasad.gatepass.controller.GatePassList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table">

    <Page
        id="gatePassPage"
        title="{i18n>gatePassTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack">

        <content>
            <VBox class="sapUiSmallMargin">

                <!-- Gate Entry Selection -->
                <VBox class="sapUiSmallMarginBottom">
                    <Title text="{i18n>gateEntryLink}" level="H5"/>
                    <Label text="{i18n>gateEntryNumber}" required="true"/>
                    <ComboBox
                        id="gateEntryCombo"
                        items="{pass>/gateEntries}"
                        change=".onGateEntryChange"
                        selectionChange=".onGateEntryChange"
                        placeholder="{i18n>selectGateEntry}">
                        <items>
                            <core:Item key="{pass>ID}" text="{pass>gateEntryNumber} - {pass>vehicleNumber} - {pass>partyName}"/>
                        </items>
                    </ComboBox>
                </VBox>

                <!-- Pass Details Form -->
                <form:SimpleForm
                    id="gatePassForm"
                    editable="true"
                    layout="ColumnLayout"
                    columnsM="2"
                    columnsL="3"
                    columnsXL="4"
                    title="{i18n>passDetails}">

                    <form:content>
                        <core:Title text="{i18n>referenceInfo}"/>

                        <Label text="{i18n>referenceType}"/>
                        <Text text="{parts: [{path: 'pass>/movementType'}], formatter: '.formatReferenceType'}"/>

                        <Label text="{i18n>referenceNumber}"/>
                        <Input value="{pass>/referenceNumber}" editable="false"/>

                        <Label text="{i18n>partyName}"/>
                        <Input value="{pass>/partyName}" editable="false"/>

                        <Label text="{i18n>partyNumber}"/>
                        <Input value="{pass>/partyNumber}" editable="false"/>

                        <core:Title text="{i18n>invoiceInfo}"/>

                        <Label text="{i18n>invoiceDate}"/>
                        <DatePicker id="invoiceDatePicker" dateValue="{pass>/invoiceDate}" displayFormat="dd-MMM-yyyy"/>

                        <Label text="{i18n>invoiceValue}"/>
                        <Input value="{pass>/invoiceValue}" type="Number"/>

                        <Label text="{i18n>eWayBillNumber}"/>
                        <Input value="{pass>/eWayBillNumber}"/>

                        <Label text="{i18n>eWayBillDate}"/>
                        <DatePicker id="eWayBillDatePicker" dateValue="{pass>/eWayBillDate}" displayFormat="dd-MMM-yyyy"/>

                        <core:Title text="{i18n>shippingInfo}"/>

                        <Label text="{i18n>shippingAddress}"/>
                        <TextArea value="{pass>/shippingAddress}" rows="3"/>

                        <core:Title text="{i18n>vehicleInfo}"/>

                        <Label text="{i18n>vehicleNumber}" required="true"/>
                        <Input id="passVehicleInput" value="{pass>/vehicleNumber}"/>

                        <Label text="{i18n>vehicleType}"/>
                        <Input value="{pass>/vehicleType}"/>

                        <Label text="{i18n>transporterName}"/>
                        <Input value="{pass>/transporterName}"/>

                        <Label text="{i18n>driverName}"/>
                        <Input value="{pass>/driverName}"/>

                        <Label text="{i18n>lrNumber}"/>
                        <Input value="{pass>/lrNumber}"/>

                        <core:Title text="{i18n>passTimestamps}"/>

                        <Label text="{i18n>passDate}" required="true"/>
                        <DatePicker id="passDatePicker" dateValue="{pass>/passDate}" displayFormat="dd-MMM-yyyy"/>

                        <Label text="{i18n>passTime}"/>
                        <TimePicker id="passTimePicker" dateValue="{pass>/passTime}"/>

                        <core:Title text="{i18n>additionalInfo}"/>

                        <Label text="{i18n>remarks}"/>
                        <TextArea value="{pass>/remarks}" rows="3"/>
                    </form:content>
                </form:SimpleForm>

                <!-- Items Table -->
                <VBox class="sapUiSmallMarginTop">
                    <Toolbar>
                        <Title text="{i18n>materialItems}" level="H5"/>
                        <ToolbarSpacer/>
                        <Button text="{i18n>addItem}" type="Emphasized" press=".onAddItem"/>
                    </Toolbar>
                    <t:Table
                        id="itemsTable"
                        rows="{pass>/items}"
                        visibleRowCount="{= ${pass>/items}.length > 0 ? ${pass>/items}.length : 3}"
                        selectionMode="None">
                        <t:columns>
                            <t:Column width="3rem">
                                <Label text="{i18n>itemNo}"/>
                                <t:template>
                                    <Text text="{pass>itemNumber}"/>
                                </t:template>
                            </t:Column>
                            <t:Column width="8rem">
                                <Label text="{i18n>materialCode}" required="true"/>
                                <t:template>
                                    <Input value="{pass>materialCode}"/>
                                </t:template>
                            </t:Column>
                            <t:Column width="12rem">
                                <Label text="{i18n>materialDescription}" required="true"/>
                                <t:template>
                                    <Input value="{pass>materialDescription}"/>
                                </t:template>
                            </t:Column>
                            <t:Column width="6rem">
                                <Label text="{i18n>quantity}" required="true"/>
                                <t:template>
                                    <Input value="{pass>quantity}" type="Number"/>
                                </t:template>
                            </t:Column>
                            <t:Column width="4rem">
                                <Label text="{i18n>unit}"/>
                                <t:template>
                                    <Input value="{pass>unitOfMeasure}"/>
                                </t:template>
                            </t:Column>
                            <t:Column width="8rem">
                                <Label text="{i18n>supplierInvoiceNo}"/>
                                <t:template>
                                    <Input value="{pass>supplierInvoiceNo}"/>
                                </t:template>
                            </t:Column>
                            <t:Column width="8rem">
                                <Label text="{i18n>supplierInvoiceDate}"/>
                                <t:template>
                                    <DatePicker dateValue="{pass>supplierInvoiceDate}" displayFormat="dd-MMM-yyyy"/>
                                </t:template>
                            </t:Column>
                            <t:Column width="5rem">
                                <Label text="{i18n>orderItem}"/>
                                <t:template>
                                    <Input value="{pass>orderItemNumber}"/>
                                </t:template>
                            </t:Column>
                            <t:Column width="3rem">
                                <Label text=""/>
                                <t:template>
                                    <Button icon="sap-icon://delete" type="Reject" press=".onRemoveItem">
                                        <customData>
                                            <core:CustomData key="index" value="{pass>itemNumber}"/>
                                        </customData>
                                    </Button>
                                </t:template>
                            </t:Column>
                        </t:columns>
                    </t:Table>
                </VBox>
            </VBox>
        </content>

        <footer>
            <Bar>
                <contentRight>
                    <Button
                        id="savePassButton"
                        text="{i18n>save}"
                        type="Emphasized"
                        press=".onSavePress"/>
                    <Button
                        id="printPassButton"
                        text="{i18n>print}"
                        press=".onPrintPress"/>
                    <Button
                        id="clearPassButton"
                        text="{i18n>clear}"
                        press=".onCancelPress"/>
                </contentRight>
            </Bar>
        </footer>
    </Page>

</mvc:View>